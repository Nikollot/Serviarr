{
    "name": "Serviarr",
    "short_name": "Serviarr",
    "start_url": "/",
    "display": "standalone",
    "background_color": "#0f172a",
    "theme_color": "#1f2937",
    "share_target": {
    "action": "/api.php?action=add_torrent&from_share=1",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "text": "text_data",
      "url": "url_data",
      "files": [
        {
          "name": "torrent_file",
          "accept": [".torrent", "application/x-bittorrent", "application/bittorrent", "application/octet-stream"]
        }
      ]
    }
  },
  "file_handlers": [
    {
      "action": "/download.php",
      "accept": {
        "application/x-bittorrent": [".torrent"]
      }
    }
  ],
    "shortcuts": [
        {
            "name": "Téléchargements",
            "short_name": "Downloads",
            "description": "Voir les téléchargements en cours",
            "url": "/download.php",
            "icons": [{ "src": "/assets/img/icons/icon.png", "sizes": "512x512", "type": "image/png" }]
        },
        {
            "name": "Ajouter un film",
            "short_name": "+ Film",
            "description": "Rechercher et ajouter un film",
            "url": "/films.php?openAdd=movie",
            "icons": [{ "src": "/assets/img/icons/icon.png", "sizes": "512x512", "type": "image/png" }]
        },
        {
            "name": "Ajouter une série",
            "short_name": "+ Série",
            "description": "Rechercher et ajouter une série",
            "url": "/series.php?openAdd=serie",
            "icons": [{ "src": "/assets/img/icons/icon.png", "sizes": "512x512", "type": "image/png" }]
        },
        {
            "name": "Recherche Prowlarr",
            "short_name": "Recherche",
            "description": "Rechercher un torrent sur tous les indexeurs",
            "url": "/prowlarr.php",
            "icons": [{ "src": "/assets/img/icons/icon.png", "sizes": "512x512", "type": "image/png" }]
        }
    ],
    "icons": [
        {
            "src": "/assets/img/icons/gemini-svg.svg",
            "sizes": "192x192",
            "type": "image/svg+xml"
        },
        {
            "src": "/assets/img/icons/icon.png",
            "sizes": "512x512",
            "type": "image/png"
        }
    ]
}
